{
  "name": "sbom-tool",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.1.0",
  "publisher": "masahirocom",
  "private": false,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/masahirocom/sbom-tool.git"
  },
  "bugs": {
    "url": "https://github.com/masahirocom/sbom-tool/issues"
  },
  "homepage": "https://github.com/masahirocom/sbom-tool#readme",
  "l10n": "./l10n",
  "keywords": [
    "sbom",
    "cyclonedx",
    "spdx",
    "vulnerability",
    "trivy",
    "npm-audit"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "files": [
    "extension.js",
    "lib/**",
    "l10n/**",
    "package.nls.json",
    "package.nls.ja.json",
    "README.md",
    "LICENSE*",
    "package.json"
  ],
  "activationEvents": [
    "onCommand:sbomTool.generateSbom",
    "onCommand:sbomTool.scanVulnerabilities",
    "onCommand:sbomTool.generateAndScan"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sbomTool.generateSbom",
        "title": "%command.generateSbom%"
      },
      {
        "command": "sbomTool.scanVulnerabilities",
        "title": "%command.scanVulnerabilities%"
      },
      {
        "command": "sbomTool.generateAndScan",
        "title": "%command.generateAndScan%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "sbomTool.outputDirectory": {
          "type": "string",
          "default": ".sbom-tool",
          "description": "%config.outputDirectory.description%"
        },
        "sbomTool.defaultSbomFormat": {
          "type": "string",
          "enum": [
            "cyclonedx-json",
            "spdx"
          ],
          "default": "cyclonedx-json",
          "description": "%config.defaultSbomFormat.description%"
        },
        "sbomTool.vulnerabilityScanner": {
          "type": "string",
          "enum": [
            "auto",
            "trivy",
            "npm-audit"
          ],
          "default": "auto",
          "description": "%config.vulnerabilityScanner.description%"
        }
      }
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.26.1"
  }
}
