{
  "name": "sbom-tool",
  "displayName": "SBOM Tool",
  "description": "Generate SBOM and run vulnerability checks for the current workspace",
  "version": "0.1.0",
  "publisher": "masahirocom",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/masahirocom/sbom-tool.git"
  },
  "bugs": {
    "url": "https://github.com/masahirocom/sbom-tool/issues"
  },
  "homepage": "https://github.com/masahirocom/sbom-tool#readme",
  "keywords": [
    "sbom",
    "cyclonedx",
    "spdx",
    "vulnerability",
    "trivy",
    "npm-audit"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "files": [
    "extension.js",
    "lib/**",
    "README.md",
    "package.json"
  ],
  "activationEvents": [
    "onCommand:sbomTool.generateSbom",
    "onCommand:sbomTool.scanVulnerabilities",
    "onCommand:sbomTool.generateAndScan"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sbomTool.generateSbom",
        "title": "SBOM Tool: Generate SBOM"
      },
      {
        "command": "sbomTool.scanVulnerabilities",
        "title": "SBOM Tool: Scan Vulnerabilities"
      },
      {
        "command": "sbomTool.generateAndScan",
        "title": "SBOM Tool: Generate SBOM + Scan Vulnerabilities"
      }
    ],
    "configuration": {
      "title": "SBOM Tool",
      "properties": {
        "sbomTool.outputDirectory": {
          "type": "string",
          "default": ".sbom-tool",
          "description": "Output directory (relative to workspace root) for generated SBOM and vulnerability reports."
        },
        "sbomTool.defaultSbomFormat": {
          "type": "string",
          "enum": [
            "cyclonedx-json",
            "spdx"
          ],
          "default": "cyclonedx-json",
          "description": "Default SBOM export format."
        },
        "sbomTool.vulnerabilityScanner": {
          "type": "string",
          "enum": [
            "auto",
            "trivy",
            "npm-audit"
          ],
          "default": "auto",
          "description": "Scanner selection for vulnerability checks. auto tries Trivy first, then npm audit."
        }
      }
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.26.1"
  }
}
